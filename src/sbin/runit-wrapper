#!/bin/sh
set -eu

main() {
  export > /env 2>/dev/null || true

  trap on_term TERM INT
  trap on_usr1 USR1
  trap on_hup HUP

  /sbin/runsvdir-start &
  runsv_pid=$!

  wait "$runsv_pid"
  exit $?
}

on_term() {
  trap '' TERM INT

  sv down /etc/service/nginx >/dev/null 2>&1 || true
  sv down /etc/service/php-fpm >/dev/null 2>&1 || true

  wait_service_down /etc/service/nginx 15
  wait_service_down /etc/service/php-fpm 15

  kill "$runsv_pid" 2>/dev/null || true
  wait "$runsv_pid" 2>/dev/null || true

  exit 0
}

wait_service_down() {
  service="$1"
  timeout="$2"
  elapsed=0

  while sv status "$service" 2>/dev/null | grep -q '^run'; do
    if [ "$elapsed" -ge "$timeout" ]; then
      echo "⚠️ timeout waiting $service to stop" >&2
      break
    fi

    sleep 1
    elapsed=$((elapsed + 1))
  done
}

on_usr1() {
  sv restart /etc/service/nginx >/dev/null 2>&1 || echo "⚠️ nginx restart failed" >&2
  sv restart /etc/service/php-fpm >/dev/null 2>&1 || echo "⚠️ php-fpm restart failed" >&2
}

on_hup() {
  sv hup /etc/service/nginx >/dev/null 2>&1 || echo "⚠️ nginx hup failed" >&2
}

main "$@"
